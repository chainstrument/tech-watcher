# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tech_watcher

# Gemini (Google AI Studio) — résumés, scoring, classification, dédup
# Clé gratuite sur https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=AIza...

# Email digest (Resend ou SMTP)
RESEND_API_KEY=re_...
DIGEST_TO_EMAIL=you@example.com

# GitHub (connecteur GitHub releases)
GITHUB_TOKEN=ghp_...

# Pipeline
PIPELINE_CRON_INTERVAL_MS=3600000
