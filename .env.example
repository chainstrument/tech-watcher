# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tech_watcher

# Anthropic (Claude API) — résumés, embeddings, scoring
ANTHROPIC_API_KEY=sk-ant-...

# Email digest (Resend ou SMTP)
